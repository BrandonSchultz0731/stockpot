<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 480px; margin: 0 auto; padding: 40px 20px;">
  <h2 style="color: #1C1512; margin-bottom: 8px;">Verify your email</h2>
  <p style="color: #8A7F78; font-size: 15px; line-height: 1.5;">
    Hi {{firstName}}, welcome to ChefPixel! Enter this code in the app to verify your email:
  </p>
  <div style="background: #FAF7F2; border-radius: 12px; padding: 24px; text-align: center; margin: 24px 0;">
    <span style="font-size: 32px; font-weight: bold; letter-spacing: 8px; color: #C25B2E;">
      {{verificationCode}}
    </span>
  </div>
  <p style="color: #8A7F78; font-size: 13px; line-height: 1.5;">
    This code expires in 15 minutes.
  </p>
</div>
